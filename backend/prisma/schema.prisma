// Prisma Schema for CollabConnect
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  skills       String[]      // Array of skills
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  projects     Project[]     // Projects posted by user
  applications Application[] // Projects applied to
}

model Project {
  id             Int           @id @default(autoincrement())
  title          String
  description    String
  skillsRequired String[]      // Required skills array
  teamSize       Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  createdBy      Int
  owner          User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  applications   Application[]
}

model Application {
  id        Int               @id @default(autoincrement())
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  userId    Int
  projectId Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId]) // Prevent duplicate applications
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}
